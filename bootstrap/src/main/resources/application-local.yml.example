# ============ 本地敏感配置模板（复制为 application-local.yml 后填写） ============
# 注意：application-local.yml 已在 .gitignore 中，严禁提交真实 API Key。
# 推荐通过环境变量提供：POSTGRES_USERNAME / POSTGRES_PASSWORD / DASHSCOPE_API_KEY / SILICONFLOW_API_KEY。

spring:
  datasource:
    username: ${POSTGRES_USERNAME:}
    password: ${POSTGRES_PASSWORD:}

xiaomi:
  agent:
    chat:
      # 阿里云百炼 API Key（qwen-plus-2025-07-28）
      api-key: ${DASHSCOPE_API_KEY:}
    embedding:
      # 硅基流动 API Key（Qwen3-Embedding-8B）
      api-key: ${SILICONFLOW_API_KEY:}
    rerank:
      # 硅基流动 API Key（Qwen3-Reranker-8B，与 embedding 共用）
      api-key: ${SILICONFLOW_API_KEY:}
