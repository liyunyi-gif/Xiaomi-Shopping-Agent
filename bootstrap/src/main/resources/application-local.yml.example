# ============ bootstrap 本地配置模板 ============
# 使用方式：复制本文件为 application-local.yml（该文件已被 .gitignore 忽略），再按本机环境修改。
# 启动时启用 local profile：-Dspring-boot.run.profiles=local

server:
  port: 8080

spring:
  # 本地无 SILICONFLOW_API_KEY 时先排除 PgVectorStore 自动装配，Knowledge 会降级为关键词路。
  # 如果要启用语义向量召回：配置 SILICONFLOW_API_KEY 后删除/注释本项。
  autoconfigure:
    exclude: org.springframework.ai.vectorstore.pgvector.autoconfigure.PgVectorStoreAutoConfiguration

  datasource:
    # PostgreSQL 需要已创建 xiaomi_agent 数据库，并执行 doc/database 下的 SQL 脚本
    url: ${POSTGRES_URL:jdbc:postgresql://192.168.122.128:5432/xiaomi_agent}
    username: ${POSTGRES_USERNAME:root}
    password: ${POSTGRES_PASSWORD:root}

  data:
    redis:
      host: ${REDIS_HOST:192.168.122.128}
      port: ${REDIS_PORT:6379}
      # 当前默认 Redis 无密码；如果你的 Redis 有密码，可取消下一行注释
      # password: ${REDIS_PASSWORD:}

  ai:
    mcp:
      client:
        sse:
          connections:
            xiaomi-shopping:
              # mcpserver 默认本机 8090 端口
              url: ${MCP_SERVER_URL:http://localhost:8090}

xiaomi:
  agent:
    chat:
      base-url: ${DASHSCOPE_BASE_URL:https://dashscope.aliyuncs.com/compatible-mode/v1}
      api-key: ${DASHSCOPE_API_KEY:}
      model: ${DASHSCOPE_CHAT_MODEL:qwen-plus-2025-07-28}

    embedding:
      base-url: ${SILICONFLOW_BASE_URL:https://api.siliconflow.cn/v1}
      api-key: ${SILICONFLOW_API_KEY:}
      model: ${SILICONFLOW_EMBEDDING_MODEL:Qwen/Qwen3-Embedding-8B}
      dimensions: ${SILICONFLOW_EMBEDDING_DIMENSIONS:1024}

    rerank:
      enabled: ${RERANK_ENABLED:true}
      base-url: ${SILICONFLOW_BASE_URL:https://api.siliconflow.cn/v1}
      api-key: ${SILICONFLOW_API_KEY:}
      model: ${SILICONFLOW_RERANK_MODEL:Qwen/Qwen3-Reranker-8B}
      retry: ${RERANK_RETRY:1}
